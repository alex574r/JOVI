<?xml version="1.0" encoding="utf-8"?>
<!--
    Jovi brand icon — bold "J" monogram, centered in 108x108 safe zone.
    Safe zone: 18dp margin on all sides → content lives in 72x72 center.
    Visual bounds of J: x=28..80, y=19..89 → center=(54,54) exactly.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        J letterform path (clockwise outline):
        - Crossbar  : (28,19) → (80,19) → (80,33) → (28,33)
        - Right arm : (66,33) → (80,33) → (80,75)
        - Outer hook: arc from (80,75) → (34,75) sweeping down to (57,89)
        - Gap wall  : (34,75) → (34,61) → (46,61) → (46,75)
        - Inner hook: arc from (46,75) → (66,75) rising to (56,67)
        - Inner arm : (66,75) → (66,33) → (28,33) → close
    -->
    <path
        android:fillColor="#173300"
        android:pathData="
            M28,19 H80 V75
            A23,14 0 0 1 34,75
            V61 H46 V75
            A10,8 0 0 0 66,75
            V33 H28 Z" />

</vector>
